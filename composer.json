{
    "name": "anibalealvarezs/facebook-graph-api",
    "description": "Comprehensive Facebook Graph API client for data extraction, supporting Ads, Pages, and Instagram metrics.",
    "license": "MIT",
    "keywords": [
        "facebook-api",
        "graph-api",
        "instagram-api",
        "facebook-ads",
        "metrics",
        "php"
    ],
    "homepage": "https://github.com/anibalealvarezs/facebook-graph-api",
    "authors": [
        {
            "name": "An\u00edbal \u00c1lvarez",
            "email": "anibalealvarezs@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/anibalealvarezs/facebook-graph-api/issues"
    },
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*",
        "symfony/yaml": "^5.4 || ^6.0 || ^7.0",
        "nesbot/carbon": "^2.61 || ^3.0",
        "anibalealvarezs/api-client-skeleton": "dev-main",
        "monolog/monolog": "^2.0 || ^3.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://satis.anibalalvarez.com/"
        }
    ],
    "autoload": {
        "psr-4": {
            "Anibalealvarezs\\FacebookGraphApi\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "fakerphp/faker": "^1.20",
        "phpunit/phpunit": "^9",
        "phpstan/phpstan": "^1.10"
    },
    "minimum-stability": "dev",
    "prefer-stable": false
}